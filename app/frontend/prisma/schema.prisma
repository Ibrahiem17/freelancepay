generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum EscrowStatus {
  ACTIVE
  SUBMITTED
  COMPLETED
  CANCELLED
  REVISION_REQUESTED
}

enum NotificationType {
  ESCROW_CREATED
  WORK_SUBMITTED
  REVISION_REQUESTED
  WORK_APPROVED
  ESCROW_CANCELLED
  PAYMENT_RELEASED
}

enum JobPostStatus {
  OPEN
  FILLED
  CLOSED
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id                        String   @id @default(cuid())
  walletAddress             String   @unique
  displayName               String?
  bio                       String?
  skills                    String[]
  hourlyRate                Decimal?
  avatarUrl                 String?
  email                     String?
  emailNotificationsEnabled Boolean  @default(true)
  isFreelancer              Boolean  @default(false)
  isClient                  Boolean  @default(false)
  averageRating             Float?
  totalReviews              Int      @default(0)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  clientEscrows     Escrow[]       @relation("ClientEscrows")
  freelancerEscrows Escrow[]       @relation("FreelancerEscrows")
  notifications     Notification[]
  jobPosts          JobPost[]
}

model Escrow {
  id               String       @id @default(cuid())
  pda              String
  network          String       @default("devnet")
  clientWallet     String
  freelancerWallet String
  amountLamports   BigInt
  title            String
  description      String
  workSubmission   String?
  revisionNote     String?
  status           EscrowStatus
  onChainCreatedAt DateTime
  lastSyncedAt     DateTime
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  client     User @relation("ClientEscrows", fields: [clientWallet], references: [walletAddress])
  freelancer User @relation("FreelancerEscrows", fields: [freelancerWallet], references: [walletAddress])

  // PDAs are unique per network (same PDA address can exist on devnet and mainnet)
  @@unique([pda, network])
  @@index([clientWallet, network])
  @@index([freelancerWallet, network])
  @@index([status, network])
  @@index([network])
}

model Notification {
  id              String           @id @default(cuid())
  recipientWallet String
  type            NotificationType
  escrowPda       String?
  title           String
  message         String
  read            Boolean          @default(false)
  createdAt       DateTime         @default(now())

  recipient User @relation(fields: [recipientWallet], references: [walletAddress])

  @@index([recipientWallet, createdAt])
}

model Review {
  id               String   @id @default(cuid())
  escrowPda        String   @unique
  clientWallet     String
  freelancerWallet String
  rating           Int
  comment          String
  createdAt        DateTime @default(now())
}

model JobPost {
  id             String        @id @default(cuid())
  clientWallet   String
  title          String
  description    String
  budgetSOL      Decimal
  requiredSkills String[]
  status         JobPostStatus @default(OPEN)
  expiresAt      DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  client User @relation(fields: [clientWallet], references: [walletAddress])

  @@index([status, createdAt])
}
